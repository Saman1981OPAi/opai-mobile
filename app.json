{
  "expo": {
    "name": "OPAi Police",
    "owner": "ebrahimi-holdings",
    "slug": "opai-police",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "opai",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
                    "weight": 700
                  }
                ]
              },
              {
                "fontFamily": "Vazirmatn",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/vazirmatn/400Regular/Vazirmatn_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/vazirmatn/500Medium/Vazirmatn_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/vazirmatn/600SemiBold/Vazirmatn_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/vazirmatn/700Bold/Vazirmatn_700Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
              "node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
              "node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
              "node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
              "node_modules/@expo-google-fonts/vazirmatn/400Regular/Vazirmatn_400Regular.ttf",
              "node_modules/@expo-google-fonts/vazirmatn/500Medium/Vazirmatn_500Medium.ttf",
              "node_modules/@expo-google-fonts/vazirmatn/600SemiBold/Vazirmatn_600SemiBold.ttf",
              "node_modules/@expo-google-fonts/vazirmatn/700Bold/Vazirmatn_700Bold.ttf"
            ]
          }
        }
      ],
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "OPAi Police uses your approximate foreground location only when you choose local weather for the Home Dashboard. Location is not tracked in the background."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#05070B"
        }
      ],
      "./modules/opai-weatherkit/app.plugin.js",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "OPAi Police uses the microphone only when you choose Audio Statement or voice translation. Recordings are saved locally. Nothing is uploaded unless you choose Transcribe or Translate."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "OPAi Police accesses only the image you select for translation.",
          "cameraPermission": "OPAi Police uses the camera only when you choose image translation."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opaiapp.police",
      "buildNumber": "25",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "OPAi Police uses your approximate foreground location only when you choose local weather for the Home Dashboard. Location is not tracked in the background.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "package": "com.opaiapp.police",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05070B"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "product": "OPAi Police",
      "domain": "opaiapp.com",
      "release": {
        "appVersion": "1.0",
        "buildNumber": "26",
        "status": "OPAi Police"
      },
      "eas": {
        "projectId": "c9044294-c57a-47f8-bb2e-15721c8882a2"
      }
    }
  }
}
