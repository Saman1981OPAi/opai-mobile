{
  "expo": {
    "name": "OPAi Police",
    "owner": "ebrahimi-holdings",
    "slug": "opai-police",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "opai",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.opaiapp.police",
      "buildNumber": "17",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.opaiapp.police",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05070B"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "product": "OPAi Police",
      "domain": "opaiapp.com",
      "release": {
        "appVersion": "0.1.0-beta",
        "buildNumber": "17",
        "status": "iOS Internal Beta / Release Candidate"
      },
      "eas": {
        "projectId": "c9044294-c57a-47f8-bb2e-15721c8882a2"
      }
    }
  }
}
