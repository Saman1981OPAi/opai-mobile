{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "22.23.1",
      "pnpm": "11.9.0",
      "corepack": true
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "internal-staging": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_OPAI_API_BASE_URL": "https://opai-backend-staging.onrender.com"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_OPAI_API_BASE_URL": "https://api.opaiapp.com"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "testflight": {
      "extends": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6788187875"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
