{
  "name": "opai-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform OPAi Police mobile application for iOS and Android.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios:staging": "eas build --platform ios --profile preview",
    "build:ios": "eas build --platform ios --profile production",
    "build:android:staging": "eas build --platform android --profile preview",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "^57.0.2",
    "expo-status-bar": "^57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.7.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^57.0.1",
    "eas-cli": "^20.5.1",
    "typescript": "^6.0.3"
  }
}
